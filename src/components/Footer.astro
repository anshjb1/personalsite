---
import { BRAND } from '../lib/constants';
---

<footer class="border-t border-line bg-soft py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between gap-8 mb-12">
      <div class="max-w-md">
        <p class="text-sm font-bold text-ink mb-2">{BRAND.owner}</p>
        <p class="text-sm text-muted leading-relaxed">{BRAND.oneLiner}</p>
      </div>
      <div class="text-right">
        <p class="text-xs font-mono text-pine">{BRAND.tagline}</p>
      </div>
    </div>

    <div class="border-t border-line pt-8 flex flex-col sm:flex-row justify-between items-center gap-4 text-xs text-muted">
      <p>&copy; {new Date().getFullYear()} Ansh Bhatt. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="/brand-guide" class="hover:text-ink transition-colors">Brand Guide</a>
        <a href="https://www.linkedin.com/in/anshbhatt/" target="_blank" rel="noopener" class="hover:text-ink transition-colors">LinkedIn</a>
      </div>
    </div>
  </div>
</footer>
