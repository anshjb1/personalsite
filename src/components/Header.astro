---
import { NAVIGATION, BRAND } from '../lib/constants';
import { Logo } from './Logo';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-b border-line">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-3 group">
        <Logo client:load size={32} />
        <div class="hidden sm:block">
          <div class="text-sm font-bold text-ink group-hover:text-pine transition-colors">{BRAND.owner}</div>
          <div class="text-[11px] text-muted">{BRAND.role}</div>
        </div>
      </a>

      <nav class="hidden lg:flex items-center gap-6">
        {NAVIGATION.map((item) => (
          <a
            href={item.href}
            class="text-[13px] font-medium text-muted hover:text-ink transition-colors"
          >
            {item.label}
          </a>
        ))}
      </nav>

      <a
        href="/contact"
        class="inline-flex items-center justify-center px-5 py-2 bg-ink text-white text-[13px] font-bold rounded-full hover:bg-ink/90 transition-all"
      >
        Book a call
      </a>
    </div>
  </div>
</header>
<div class="h-16"></div>
