---
import Layout from '../layouts/Layout.astro';
import { Card } from '../components/Card';
import { FRAMEWORK } from '../lib/constants';
---

<Layout title="Approach — Ansh Bhatt">
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-h3 text-muted mb-3">Approach</p>
      <h1 class="text-h1 text-ink mb-6">How I Work</h1>
      <p class="text-lg text-muted">
        A repeatable framework that replaces guesswork with clarity.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <h2 class="text-2xl font-black text-ink mb-10">{FRAMEWORK.title}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {FRAMEWORK.steps.map((step, i) => (
          <Card client:load variant="soft" className="relative">
            <div class="absolute top-4 right-4 w-8 h-8 rounded-full border border-line flex items-center justify-center text-pine font-bold text-sm">
              {i + 1}
            </div>
            <h3 class="text-lg font-bold text-ink mb-2">{step.title}</h3>
            <p class="text-sm text-muted">{step.desc}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-soft">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-black text-ink mb-10">Weekly Operating Cadence</h2>
      <div class="space-y-6">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-pine text-white flex items-center justify-center text-sm">1</div>
          <div>
            <h3 class="font-bold text-ink mb-1">Status</h3>
            <p class="text-sm text-muted">What got done. What didn't. Why.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-pine text-white flex items-center justify-center text-sm">2</div>
          <div>
            <h3 class="font-bold text-ink mb-1">Risks</h3>
            <p class="text-sm text-muted">What's blocking. What could break. Mitigation moves.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-pine text-white flex items-center justify-center text-sm">3</div>
          <div>
            <h3 class="font-bold text-ink mb-1">Decisions</h3>
            <p class="text-sm text-muted">What needs to be decided. Owner. Deadline.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-pine text-white flex items-center justify-center text-sm">4</div>
          <div>
            <h3 class="font-bold text-ink mb-1">Next Actions</h3>
            <p class="text-sm text-muted">Who does what by when. No ambiguity.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-black text-ink mb-10">Voice & Principles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h3 class="font-bold text-ink mb-2">Discreet</h3>
          <p class="text-muted">Outcomes > announcements. No hype. Work speaks.</p>
        </div>
        <div>
          <h3 class="font-bold text-ink mb-2">Precise</h3>
          <p class="text-muted">Assumptions stated. Tradeoffs explicit. No hidden agendas.</p>
        </div>
        <div>
          <h3 class="font-bold text-ink mb-2">Measured</h3>
          <p class="text-muted">Senior-level thinking. No false urgency. Risk managed.</p>
        </div>
        <div>
          <h3 class="font-bold text-ink mb-2">Decisive</h3>
          <p class="text-muted">Clear owners. Hard dates. Accountability built in.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
