---
import Layout from '../layouts/Layout.astro';
import { Logo } from '../components/Logo';
import { COLORS, BRAND } from '../lib/constants';
---

<Layout title="Brand Guide — Ansh Bhatt">
  <style>
    @media print {
      body { margin: 0; padding: 0; }
      .print-page { page-break-after: always; break-after: page; }
      .no-break { break-inside: avoid; }
      @page { margin: 0; size: letter; }
      .sheet { margin: 0; box-shadow: none; }
      .print-btn { display: none; }
      header, footer { display: none !important; }
    }
    .sheet {
      width: 8.5in;
      min-height: 11in;
      margin: 0 auto 1rem;
      padding: 0.65in;
      background: white;
      box-shadow: 0 1px 4px rgba(0,0,0,0.08);
      display: flex;
      flex-direction: column;
    }
  </style>

  <div class="py-8">
    <div class="print-btn flex justify-center mb-8">
      <button
        onclick="window.print()"
        class="px-6 py-3 rounded-full font-bold bg-ink text-white hover:bg-ink/90 transition text-sm"
      >
        Download as PDF
      </button>
    </div>

    <div class="sheet print-page">
      <div class="flex-1">
        <h1 class="text-h1 text-ink mb-2">{BRAND.owner}</h1>
        <p class="text-h2 text-pine mb-12">Brand Guide</p>

        <div class="mb-8">
          <p class="text-h3 text-muted mb-3">Tagline</p>
          <p class="text-2xl font-bold text-ink">{BRAND.tagline}</p>
        </div>

        <div>
          <p class="text-h3 text-muted mb-3">One-Liner</p>
          <p class="text-ink leading-relaxed">{BRAND.oneLiner}</p>
        </div>
      </div>
      <div class="border-t border-line pt-4 text-xs text-muted">
        <p>Page 1</p>
      </div>
    </div>

    <div class="sheet print-page">
      <h2 class="text-2xl font-black text-ink mb-8">Color Palette</h2>
      <div class="space-y-5 flex-1">
        <div class="no-break flex gap-4 items-center">
          <div class="w-16 h-16 rounded border border-line" style={`background: ${COLORS.pine}`}></div>
          <div>
            <p class="font-bold text-ink">Pine</p>
            <p class="text-xs font-mono text-muted">{COLORS.pine}</p>
            <p class="text-xs text-muted">Primary brand, headings, accents</p>
          </div>
        </div>
        <div class="no-break flex gap-4 items-center">
          <div class="w-16 h-16 rounded border border-line" style={`background: ${COLORS.pineInk}`}></div>
          <div>
            <p class="font-bold text-ink">Deep Pine</p>
            <p class="text-xs font-mono text-muted">{COLORS.pineInk}</p>
            <p class="text-xs text-muted">Shadows, depth</p>
          </div>
        </div>
        <div class="no-break flex gap-4 items-center">
          <div class="w-16 h-16 rounded border border-line" style={`background: ${COLORS.blue}`}></div>
          <div>
            <p class="font-bold text-ink">Blue</p>
            <p class="text-xs font-mono text-muted">{COLORS.blue}</p>
            <p class="text-xs text-muted">CTAs, links, emphasis</p>
          </div>
        </div>
        <div class="no-break flex gap-4 items-center">
          <div class="w-16 h-16 rounded border border-line" style={`background: ${COLORS.ink}`}></div>
          <div>
            <p class="font-bold text-ink">Ink</p>
            <p class="text-xs font-mono text-muted">{COLORS.ink}</p>
            <p class="text-xs text-muted">Body text, primary UI</p>
          </div>
        </div>
        <div class="no-break flex gap-4 items-center">
          <div class="w-16 h-16 rounded border border-line" style={`background: ${COLORS.muted}`}></div>
          <div>
            <p class="font-bold text-ink">Muted</p>
            <p class="text-xs font-mono text-muted">{COLORS.muted}</p>
            <p class="text-xs text-muted">Captions, secondary text</p>
          </div>
        </div>
      </div>
      <div class="border-t border-line pt-4 text-xs text-muted mt-8">
        <p>Page 2</p>
      </div>
    </div>

    <div class="sheet print-page">
      <h2 class="text-2xl font-black text-ink mb-8">Logo</h2>
      <div class="flex-1">
        <div class="no-break mb-8">
          <p class="text-sm font-bold text-ink mb-4">Primary Mark</p>
          <div class="flex items-center gap-8 p-8 bg-soft rounded-card border border-line">
            <Logo client:load size={80} />
            <div>
              <p class="text-sm text-muted">Isometric Polygon</p>
              <p class="text-xs text-muted mt-2">Three-face isometric cube with blue top, pine left, deep pine right.</p>
            </div>
          </div>
        </div>
        <div class="no-break">
          <p class="text-sm font-bold text-ink mb-4">Logo Rules</p>
          <ul class="text-xs text-muted space-y-2">
            <li><span class="font-bold text-ink">Clear space:</span> Minimum 0.5x icon width</li>
            <li><span class="font-bold text-ink">Minimum size:</span> 28px (digital), 0.25" (print)</li>
            <li><span class="font-bold text-ink">Don't:</span> Add shadows, stretch, modify colors, or use on busy backgrounds</li>
          </ul>
        </div>
      </div>
      <div class="border-t border-line pt-4 text-xs text-muted mt-8">
        <p>Page 3</p>
      </div>
    </div>

    <div class="sheet print-page">
      <h2 class="text-2xl font-black text-ink mb-8">Typography</h2>
      <div class="space-y-6 flex-1">
        <div class="no-break">
          <p class="text-h3 text-muted mb-2">H1 / Hero Title</p>
          <p class="text-4xl font-black text-ink mb-2">42px / Black / -0.045em</p>
          <p class="text-xs text-muted">Cover titles, major headings</p>
        </div>
        <div class="no-break">
          <p class="text-h3 text-muted mb-2">H2 / Section Lead</p>
          <p class="text-2xl font-bold text-ink mb-2">22px / Bold / -0.03em</p>
          <p class="text-xs text-muted">Section headings, statements</p>
        </div>
        <div class="no-break">
          <p class="text-h3 text-muted mb-2">H3 / Eyebrow</p>
          <p class="text-h3 text-ink mb-2">12px / Black / +0.10em</p>
          <p class="text-xs text-muted">Labels, section eyebrows</p>
        </div>
        <div class="no-break">
          <p class="text-h3 text-muted mb-2">Body</p>
          <p class="text-ink mb-2">15px / 450-550 weight / 1.5 line height</p>
          <p class="text-xs text-muted">Paragraphs, main content</p>
        </div>
      </div>
      <div class="border-t border-line pt-4 text-xs text-muted mt-8">
        <p>Page 4</p>
      </div>
    </div>

    <div class="sheet print-page">
      <h2 class="text-2xl font-black text-ink mb-8">Voice & Principles</h2>
      <div class="space-y-5 flex-1">
        <div class="no-break">
          <h3 class="font-bold text-ink mb-1">Discreet</h3>
          <p class="text-sm text-muted">Outcomes > announcements. Let the work speak.</p>
        </div>
        <div class="no-break">
          <h3 class="font-bold text-ink mb-1">Precise</h3>
          <p class="text-sm text-muted">Assumptions stated. Tradeoffs explicit. No hidden agendas.</p>
        </div>
        <div class="no-break">
          <h3 class="font-bold text-ink mb-1">Measured</h3>
          <p class="text-sm text-muted">Senior-level thinking. No hype. Risk managed.</p>
        </div>
        <div class="no-break">
          <h3 class="font-bold text-ink mb-1">Decisive</h3>
          <p class="text-sm text-muted">Clear owners, hard dates. Accountability built in.</p>
        </div>
        <div class="mt-8">
          <p class="text-h3 text-muted mb-4">Signature Lines</p>
          <ul class="space-y-2">
            <li class="text-sm text-ink italic">"Clarity you can execute."</li>
            <li class="text-sm text-ink italic">"Senior-level thinking, founder-speed delivery."</li>
            <li class="text-sm text-ink italic">"Risk reduced. Momentum increased."</li>
          </ul>
        </div>
      </div>
      <div class="border-t border-line pt-4 text-xs text-muted mt-8">
        <p>Page 5</p>
      </div>
    </div>

    <div class="sheet">
      <h2 class="text-2xl font-black text-ink mb-8">Framework</h2>
      <div class="flex-1">
        <h3 class="text-xl font-black text-ink mb-6">Problem - Plan - Path - Proof</h3>
        <div class="space-y-5">
          <div>
            <p class="font-bold text-pine">Problem</p>
            <p class="text-sm text-muted">What's true now? Current state, constraints, blockers.</p>
          </div>
          <div>
            <p class="font-bold text-pine">Plan</p>
            <p class="text-sm text-muted">2-3 options + tradeoffs. Clear thinking. Different paths forward.</p>
          </div>
          <div>
            <p class="font-bold text-pine">Path</p>
            <p class="text-sm text-muted">First 2 weeks + first 90 days. Sequenced, owned, dated.</p>
          </div>
          <div>
            <p class="font-bold text-pine">Proof</p>
            <p class="text-sm text-muted">Checkpoints, KPIs, owner, due date. Measure what matters.</p>
          </div>
        </div>
      </div>
      <div class="border-t border-line pt-4 text-xs text-muted mt-8">
        <p>&copy; {new Date().getFullYear()} {BRAND.owner}</p>
      </div>
    </div>
  </div>
</Layout>
