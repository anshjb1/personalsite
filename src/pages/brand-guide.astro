---
import Layout from '../layouts/Layout.astro';
import { Logo } from '../components/Logo';
import { BRAND, COLORS, SERVICES, FRAMEWORK, SIGNATURE_LINES } from '../lib/constants';
---

<Layout title="Brand Guide — Ansh Bhatt">
  <style>
    @media print {
      body { margin: 0; padding: 0; }
      header, footer, .no-print { display: none !important; }
      .sheet { page-break-after: always; break-after: page; box-shadow: none !important; margin: 0 !important; }
      @page { margin: 0; size: letter; }
    }
    .sheet {
      width: 8.5in;
      min-height: 11in;
      margin: 0 auto 24px;
      padding: 0.65in;
      background: white;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
      display: flex;
      flex-direction: column;
      box-sizing: border-box;
    }
    @media (max-width: 900px) {
      .sheet {
        width: 100%;
        min-height: auto;
        padding: 40px 24px;
      }
    }
  </style>

  <div style="background:#F6F6F6;min-height:100vh;padding:40px 0 60px;">

    <div class="no-print" style="max-width:8.5in;margin:0 auto 32px;padding:0 24px;display:flex;justify-content:space-between;align-items:center;">
      <div style="font-size:12px;color:#5F5F5F;">Brand Guide — {new Date().getFullYear()}</div>
      <button
        onclick="window.print()"
        style="display:inline-flex;align-items:center;padding:10px 22px;background:#0B0B0B;color:#fff;border:none;border-radius:999px;font-size:13px;font-weight:700;cursor:pointer;transition:opacity 0.15s ease;"
        onmouseover="this.style.opacity='0.85'"
        onmouseout="this.style.opacity='1'"
      >
        Download PDF
      </button>
    </div>

    <!-- Page 1: Identity -->
    <div class="sheet">
      <div style="flex:1;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:64px;">
          <div>
            <div style="font-size:10px;font-weight:900;letter-spacing:0.12em;text-transform:uppercase;color:#0B3D2E;margin-bottom:16px;">
              Brand Guide
            </div>
            <h1 style="font-size:42px;font-weight:900;letter-spacing:-0.045em;line-height:1.12;color:#0B0B0B;margin:0 0 8px;">
              {BRAND.name}
            </h1>
            <p style="font-size:16px;font-weight:700;letter-spacing:-0.02em;color:#0B3D2E;margin:0;">
              Startup Consultant
            </p>
          </div>
          <Logo client:load size={64} showWordmark={false} />
        </div>

        <div style="border-top:1px solid #E8E8E8;padding-top:40px;display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-bottom:40px;">
          <div>
            <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:12px;">Tagline</div>
            <p style="font-size:20px;font-weight:800;letter-spacing:-0.03em;color:#0B0B0B;margin:0;">{BRAND.tagline}</p>
          </div>
          <div>
            <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:12px;">One-Liner</div>
            <p style="font-size:13px;color:#5F5F5F;line-height:1.65;margin:0;">{BRAND.oneLiner}</p>
          </div>
        </div>

        <div style="border-top:1px solid #E8E8E8;padding-top:40px;">
          <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:16px;">Vibe</div>
          <div style="display:flex;flex-wrap:wrap;gap:8px;">
            {["bold","modern","premium","minimal","discreet","operator-led"].map((v) => (
              <span style="display:inline-flex;align-items:center;padding:5px 14px;border:1px solid #E8E8E8;border-radius:999px;font-size:11.5px;font-weight:600;color:#0B0B0B;">{v}</span>
            ))}
          </div>
        </div>
      </div>
      <div style="border-top:1px solid #E8E8E8;padding-top:14px;display:flex;justify-content:space-between;align-items:center;">
        <span style="font-size:10px;font-family:ui-monospace,monospace;color:#5F5F5F;">&copy; {new Date().getFullYear()} {BRAND.name}</span>
        <span style="font-size:10px;color:#5F5F5F;">Page 1</span>
      </div>
    </div>

    <!-- Page 2: Color Palette -->
    <div class="sheet">
      <div style="flex:1;">
        <h2 style="font-size:22px;font-weight:800;letter-spacing:-0.03em;color:#0B0B0B;margin:0 0 40px;">Color Palette</h2>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
          {[
            { name: "Pine", hex: COLORS.pine, use: "Primary brand, headings, accents" },
            { name: "Deep Pine", hex: COLORS.pineInk, use: "Icon shadow face, depth" },
            { name: "Blue", hex: COLORS.blue, use: "CTAs, links, select emphasis" },
            { name: "Ink", hex: COLORS.ink, use: "Body text, borders, primary UI" },
            { name: "Muted", hex: COLORS.muted, use: "Captions, labels, secondary text" },
            { name: "Line", hex: COLORS.line, use: "Dividers, table rules, borders" },
            { name: "White", hex: COLORS.bg, use: "Backgrounds" },
            { name: "Soft", hex: COLORS.soft, use: "Subtle panels, card alt bg" },
          ].map((color) => (
            <div style="display:flex;align-items:center;gap:14px;padding:16px;border:1px solid #E8E8E8;border-radius:10px;background:#fff;">
              <div style={`width:44px;height:44px;border-radius:8px;background:${color.hex};border:1px solid rgba(0,0,0,0.08);flex-shrink:0;`}></div>
              <div>
                <div style="font-size:13px;font-weight:700;color:#0B0B0B;margin-bottom:2px;">{color.name}</div>
                <div style="font-size:10.5px;font-family:ui-monospace,monospace;color:#5F5F5F;margin-bottom:3px;">{color.hex}</div>
                <div style="font-size:11px;color:#5F5F5F;">{color.use}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div style="border-top:1px solid #E8E8E8;padding-top:14px;display:flex;justify-content:space-between;align-items:center;margin-top:32px;">
        <span style="font-size:10px;font-family:ui-monospace,monospace;color:#5F5F5F;">&copy; {new Date().getFullYear()} {BRAND.name}</span>
        <span style="font-size:10px;color:#5F5F5F;">Page 2</span>
      </div>
    </div>

    <!-- Page 3: Logo -->
    <div class="sheet">
      <div style="flex:1;">
        <h2 style="font-size:22px;font-weight:800;letter-spacing:-0.03em;color:#0B0B0B;margin:0 0 40px;">Logo</h2>

        <div style="border:1px solid #E8E8E8;border-radius:14px;padding:40px;background:#F6F6F6;display:flex;align-items:center;gap:40px;margin-bottom:32px;">
          <Logo client:load size={96} showWordmark={false} />
          <div style="display:flex;flex-direction:column;gap:20px;">
            <div>
              <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:6px;">Name</div>
              <div style="font-size:13px;color:#0B0B0B;font-weight:600;">Isometric Polygon</div>
            </div>
            <div>
              <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:6px;">Intent</div>
              <div style="font-size:13px;color:#5F5F5F;">Architectural · Premium · Clean</div>
            </div>
            <div>
              <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:6px;">Faces</div>
              <div style="font-size:12px;color:#5F5F5F;font-family:ui-monospace,monospace;line-height:1.6;">
                Top: #1E5EFF<br/>Left: #0B3D2E<br/>Right: #082B21
              </div>
            </div>
          </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
          <div style="padding:24px;border:1px solid #E8E8E8;border-radius:10px;background:#fff;">
            <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:14px;">Size Rules</div>
            <div style="display:flex;flex-direction:column;gap:8px;">
              <div style="font-size:12px;color:#0B0B0B;">Min digital: <span style="font-family:ui-monospace,monospace;">28px</span></div>
              <div style="font-size:12px;color:#0B0B0B;">Min print: <span style="font-family:ui-monospace,monospace;">0.25in</span></div>
              <div style="font-size:12px;color:#0B0B0B;">Clear space: <span style="font-family:ui-monospace,monospace;">0.5x width</span></div>
            </div>
          </div>
          <div style="padding:24px;border:1px solid #E8E8E8;border-radius:10px;background:#fff;">
            <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:14px;">Don'ts</div>
            <div style="display:flex;flex-direction:column;gap:6px;">
              {["No shadows on mark","No extra facets","No color swaps","No stretching","No busy backgrounds"].map((d) => (
                <div style="display:flex;align-items:center;gap:8px;font-size:12px;color:#5F5F5F;">
                  <span style="color:#d0d0d0;">✕</span>{d}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
      <div style="border-top:1px solid #E8E8E8;padding-top:14px;display:flex;justify-content:space-between;align-items:center;margin-top:32px;">
        <span style="font-size:10px;font-family:ui-monospace,monospace;color:#5F5F5F;">&copy; {new Date().getFullYear()} {BRAND.name}</span>
        <span style="font-size:10px;color:#5F5F5F;">Page 3</span>
      </div>
    </div>

    <!-- Page 4: Typography -->
    <div class="sheet">
      <div style="flex:1;">
        <h2 style="font-size:22px;font-weight:800;letter-spacing:-0.03em;color:#0B0B0B;margin:0 0 40px;">Typography</h2>
        <div style="display:flex;flex-direction:column;gap:0;">
          {[
            { label: "H1 / Hero Title", specimen: "Sample Heading", style: { fontSize: '42px', fontWeight: 900, letterSpacing: '-0.045em', lineHeight: '1.12', color: '#0B0B0B' }, spec: "42px · 900 · -0.045em · 1.12 · Cover titles" },
            { label: "H2 / Section Lead", specimen: "Section Heading", style: { fontSize: '22px', fontWeight: 800, letterSpacing: '-0.03em', lineHeight: '1.2', color: '#0B0B0B' }, spec: "22px · 800 · -0.03em · Section leads" },
            { label: "H3 / Eyebrow", specimen: "EYEBROW LABEL", style: { fontSize: '12px', fontWeight: 900, letterSpacing: '0.10em', textTransform: 'uppercase' as const, color: '#0B3D2E' }, spec: "12px · 900 · +0.10em · uppercase · Labels" },
            { label: "Body", specimen: "Body text for paragraphs and main content flows at a comfortable reading size.", style: { fontSize: '15px', fontWeight: 500, lineHeight: '1.65', color: '#5F5F5F' }, spec: "15px · 450-550 · 1.65 · Paragraphs" },
            { label: "Small / Caption", specimen: "Caption text, meta, secondary info", style: { fontSize: '12px', fontWeight: 500, color: '#5F5F5F' }, spec: "12px · 450-650 · Captions" },
            { label: "Mono / Spec", specimen: "const value = 'specification';", style: { fontSize: '12px', fontFamily: 'ui-monospace,monospace', fontWeight: 400, color: '#5F5F5F' }, spec: "10pt · monospace · Tokens, specs" },
          ].map((item, i) => (
            <div style={`display:grid;grid-template-columns:140px 1fr 180px;gap:16px;padding:20px 0;align-items:center;${i < 5 ? 'border-bottom:1px solid #E8E8E8;' : ''}`}>
              <div style="font-size:10px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:#5F5F5F;">{item.label}</div>
              <div style={Object.entries(item.style).map(([k,v]) => `${k.replace(/[A-Z]/g,m=>'-'+m.toLowerCase())}:${v}`).join(';')}>{item.specimen}</div>
              <div style="font-size:10px;font-family:ui-monospace,monospace;color:#5F5F5F;line-height:1.5;">{item.spec}</div>
            </div>
          ))}
        </div>
      </div>
      <div style="border-top:1px solid #E8E8E8;padding-top:14px;display:flex;justify-content:space-between;align-items:center;margin-top:32px;">
        <span style="font-size:10px;font-family:ui-monospace,monospace;color:#5F5F5F;">&copy; {new Date().getFullYear()} {BRAND.name}</span>
        <span style="font-size:10px;color:#5F5F5F;">Page 4</span>
      </div>
    </div>

    <!-- Page 5: Voice + Framework -->
    <div class="sheet">
      <div style="flex:1;">
        <h2 style="font-size:22px;font-weight:800;letter-spacing:-0.03em;color:#0B0B0B;margin:0 0 40px;">Voice &amp; Framework</h2>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-bottom:40px;">
          <div>
            <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:20px;">Principles</div>
            {[
              { title: "Discreet", body: "Outcomes over announcements." },
              { title: "Precise", body: "Assumptions stated explicitly." },
              { title: "Measured", body: "No hype. KPIs tracked." },
              { title: "Decisive", body: "Owners + dates on everything." },
            ].map((p) => (
              <div style="display:flex;gap:12px;margin-bottom:14px;">
                <div style="width:4px;height:4px;background:#0B3D2E;border-radius:50%;flex-shrink:0;margin-top:6px;"></div>
                <div>
                  <span style="font-size:13px;font-weight:700;color:#0B0B0B;">{p.title}</span>
                  <span style="font-size:13px;color:#5F5F5F;"> — {p.body}</span>
                </div>
              </div>
            ))}
          </div>

          <div>
            <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:20px;">Signature Lines</div>
            {SIGNATURE_LINES.map((line) => (
              <div style="font-size:13px;font-style:italic;color:#0B0B0B;margin-bottom:10px;">"{line}"</div>
            ))}
          </div>
        </div>

        <div style="border-top:1px solid #E8E8E8;padding-top:32px;">
          <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:20px;">{FRAMEWORK.title}</div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
            {FRAMEWORK.steps.map((step) => (
              <div style="padding:20px;border:1px solid #E8E8E8;border-radius:10px;background:#F6F6F6;">
                <div style="font-size:13px;font-weight:800;letter-spacing:-0.02em;color:#0B3D2E;margin-bottom:6px;">{step.label}</div>
                <p style="font-size:12px;color:#5F5F5F;line-height:1.55;margin:0;">{step.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div style="border-top:1px solid #E8E8E8;padding-top:14px;display:flex;justify-content:space-between;align-items:center;margin-top:32px;">
        <span style="font-size:10px;font-family:ui-monospace,monospace;color:#5F5F5F;">&copy; {new Date().getFullYear()} {BRAND.name}</span>
        <span style="font-size:10px;color:#5F5F5F;">Page 5</span>
      </div>
    </div>

    <!-- Page 6: UI Components -->
    <div class="sheet">
      <div style="flex:1;">
        <h2 style="font-size:22px;font-weight:800;letter-spacing:-0.03em;color:#0B0B0B;margin:0 0 40px;">UI Components</h2>

        <div style="display:flex;flex-direction:column;gap:36px;">
          <div>
            <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:16px;">Buttons</div>
            <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:center;">
              <button style="padding:11px 24px;background:#0B0B0B;color:#fff;border:none;border-radius:999px;font-size:13px;font-weight:700;cursor:default;">Primary</button>
              <button style="padding:11px 24px;background:linear-gradient(135deg,#0B3D2E,#1E5EFF);color:#fff;border:none;border-radius:999px;font-size:13px;font-weight:700;cursor:default;">Accent</button>
              <button style="padding:10px 24px;background:#fff;color:#0B0B0B;border:1.5px solid #0B0B0B;border-radius:999px;font-size:13px;font-weight:600;cursor:default;">Secondary</button>
            </div>
          </div>

          <div>
            <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:16px;">Cards</div>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
              <div style="border:1px solid #E8E8E8;border-radius:14px;padding:24px;background:#fff;">
                <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:8px;">Card White</div>
                <p style="font-size:13px;color:#5F5F5F;margin:0;line-height:1.5;">Default card variant. Used for content blocks, service cards, and data displays.</p>
              </div>
              <div style="border:1px solid #E8E8E8;border-radius:14px;padding:24px;background:#F6F6F6;">
                <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:8px;">Card Soft</div>
                <p style="font-size:13px;color:#5F5F5F;margin:0;line-height:1.5;">Soft bg variant. Used for callouts, FAQ panels, and alternate sections.</p>
              </div>
            </div>
          </div>

          <div>
            <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:16px;">Pills / Tags</div>
            <div style="display:flex;flex-wrap:wrap;gap:8px;">
              {["Legal","Accounting","Software Engineering","Marketing","Healthtech","Fintech"].map((tag) => (
                <span style="display:inline-flex;align-items:center;padding:6px 14px;border:1px solid #E8E8E8;border-radius:999px;font-size:12px;font-weight:600;color:#0B0B0B;background:#fff;">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
      <div style="border-top:1px solid #E8E8E8;padding-top:14px;display:flex;justify-content:space-between;align-items:center;margin-top:32px;">
        <span style="font-size:10px;font-family:ui-monospace,monospace;color:#5F5F5F;">&copy; {new Date().getFullYear()} {BRAND.name}</span>
        <span style="font-size:10px;color:#5F5F5F;">Page 6</span>
      </div>
    </div>

  </div>
</Layout>
