---
import Layout from '../layouts/Layout.astro';
import { BRAND } from '../lib/constants';
---

<Layout
  title="Contact — Ansh Bhatt"
  description="Book a call with Ansh Bhatt. Share your constraints and I'll map the fastest safe path forward."
>

  <section style="padding:80px 0 64px;border-bottom:1px solid #E8E8E8;">
    <div style="max-width:1120px;margin:0 auto;padding:0 32px;">
      <div style="font-size:11px;font-weight:900;letter-spacing:0.12em;text-transform:uppercase;color:#0B3D2E;margin-bottom:16px;">Contact</div>
      <h1 style="font-size:clamp(32px,5vw,50px);font-weight:900;letter-spacing:-0.042em;line-height:1.1;color:#0B0B0B;margin:0 0 20px;max-width:520px;">
        Let's talk.
      </h1>
      <p style="font-size:15px;color:#5F5F5F;line-height:1.65;max-width:480px;margin:0;">
        Share what you're working on—constraints, timelines, current status. I'll map the fastest safe path forward.
      </p>
    </div>
  </section>

  <section style="padding:72px 0;border-bottom:1px solid #E8E8E8;">
    <div style="max-width:1120px;margin:0 auto;padding:0 32px;">
      <div style="display:grid;grid-template-columns:1fr 1.2fr;gap:80px;align-items:start;" class="block md:grid">

        <div>
          <div style="font-size:11px;font-weight:900;letter-spacing:0.12em;text-transform:uppercase;color:#0B3D2E;margin-bottom:28px;">
            What to expect
          </div>
          <div style="display:flex;flex-direction:column;gap:0;">
            {[
              { label: "Response time", body: "Usually within 24 hours on weekdays." },
              { label: "Initial call", body: "30 minutes. No cost, no pressure. We map context and constraints." },
              { label: "Outcome", body: "Clear next steps and an honest assessment of whether I can help." },
            ].map((item, i) => (
              <div style={`padding:20px 0;${i < 2 ? 'border-bottom:1px solid #E8E8E8;' : ''}`}>
                <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:6px;">{item.label}</div>
                <p style="font-size:14px;color:#0B0B0B;line-height:1.55;margin:0;font-weight:500;">{item.body}</p>
              </div>
            ))}
          </div>

          <div style="margin-top:40px;padding-top:32px;border-top:1px solid #E8E8E8;">
            <div style="font-size:11px;font-weight:900;letter-spacing:0.12em;text-transform:uppercase;color:#0B3D2E;margin-bottom:16px;">
              Direct contact
            </div>
            <div style="display:flex;flex-direction:column;gap:8px;">
              <a href={`mailto:${BRAND.email}`} style="font-size:14px;color:#1E5EFF;font-weight:600;text-decoration:none;letter-spacing:-0.01em;">{BRAND.email}</a>
              <a href="https://www.linkedin.com/in/anshbhatt/" target="_blank" rel="noopener" style="font-size:14px;color:#5F5F5F;font-weight:500;text-decoration:none;">LinkedIn</a>
            </div>
          </div>
        </div>

        <div style="background:#F6F6F6;border:1px solid #E8E8E8;border-radius:14px;padding:36px;">
          <form
            id="contact-form"
            style="display:flex;flex-direction:column;gap:20px;"
            onsubmit="handleSubmit(event)"
          >
            <div>
              <label for="name" style="display:block;font-size:12px;font-weight:700;color:#0B0B0B;letter-spacing:0.03em;text-transform:uppercase;margin-bottom:8px;">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your name"
                style="width:100%;padding:11px 14px;border:1.5px solid #E8E8E8;border-radius:8px;font-size:14px;color:#0B0B0B;background:#fff;outline:none;transition:border-color 0.15s ease;box-sizing:border-box;"
                onfocus="this.style.borderColor='#0B3D2E'"
                onblur="this.style.borderColor='#E8E8E8'"
              />
            </div>

            <div>
              <label for="email" style="display:block;font-size:12px;font-weight:700;color:#0B0B0B;letter-spacing:0.03em;text-transform:uppercase;margin-bottom:8px;">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="you@company.com"
                style="width:100%;padding:11px 14px;border:1.5px solid #E8E8E8;border-radius:8px;font-size:14px;color:#0B0B0B;background:#fff;outline:none;transition:border-color 0.15s ease;box-sizing:border-box;"
                onfocus="this.style.borderColor='#0B3D2E'"
                onblur="this.style.borderColor='#E8E8E8'"
              />
            </div>

            <div>
              <label for="company" style="display:block;font-size:12px;font-weight:700;color:#0B0B0B;letter-spacing:0.03em;text-transform:uppercase;margin-bottom:8px;">Company <span style="font-weight:400;color:#5F5F5F;">(optional)</span></label>
              <input
                type="text"
                id="company"
                name="company"
                placeholder="Your company or project"
                style="width:100%;padding:11px 14px;border:1.5px solid #E8E8E8;border-radius:8px;font-size:14px;color:#0B0B0B;background:#fff;outline:none;transition:border-color 0.15s ease;box-sizing:border-box;"
                onfocus="this.style.borderColor='#0B3D2E'"
                onblur="this.style.borderColor='#E8E8E8'"
              />
            </div>

            <div>
              <label for="message" style="display:block;font-size:12px;font-weight:700;color:#0B0B0B;letter-spacing:0.03em;text-transform:uppercase;margin-bottom:8px;">What's on your plate?</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                placeholder="Share your constraints, timeline, current status..."
                style="width:100%;padding:11px 14px;border:1.5px solid #E8E8E8;border-radius:8px;font-size:14px;color:#0B0B0B;background:#fff;outline:none;transition:border-color 0.15s ease;resize:none;box-sizing:border-box;font-family:inherit;"
                onfocus="this.style.borderColor='#0B3D2E'"
                onblur="this.style.borderColor='#E8E8E8'"
              ></textarea>
            </div>

            <button
              type="submit"
              style="width:100%;padding:13px;background:#0B0B0B;color:#fff;border:none;border-radius:999px;font-size:14px;font-weight:700;letter-spacing:-0.01em;cursor:pointer;transition:opacity 0.15s ease;"
              onmouseover="this.style.opacity='0.85'"
              onmouseout="this.style.opacity='1'"
            >
              Send message
            </button>

            <div id="form-success" style="display:none;padding:14px;background:#0B3D2E;color:#fff;border-radius:8px;font-size:13px;font-weight:600;text-align:center;">
              Message sent. I'll be in touch within 24 hours.
            </div>
          </form>
        </div>

      </div>
    </div>
  </section>

  <section style="background:#0B3D2E;padding:80px 0;">
    <div style="max-width:1120px;margin:0 auto;padding:0 32px;text-align:center;">
      <h2 style="font-size:clamp(22px,4vw,38px);font-weight:900;letter-spacing:-0.04em;line-height:1.1;color:#fff;margin:0 0 12px;">
        If it's high-stakes, we'll make it simple.
      </h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);margin:0;">
        High-stakes work demands senior thinking.
      </p>
    </div>
  </section>

</Layout>

<script>
  function handleSubmit(e: Event) {
    e.preventDefault();
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const success = document.getElementById('form-success');
    if (form && success) {
      form.style.opacity = '0.5';
      form.style.pointerEvents = 'none';
      success.style.display = 'block';
    }
  }
  (window as any).handleSubmit = handleSubmit;
</script>
