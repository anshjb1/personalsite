---
import Layout from '../layouts/Layout.astro';
import { BRAND, PROOF_ITEMS, SERVICES, APPROACH_STEPS, BENCH_AREAS } from '../lib/constants';
---

<Layout title="Ansh Bhatt — Startup Consultant" description={BRAND.oneLiner}>

  <section style="padding:100px 0 88px;border-bottom:1px solid #E8E8E8;">
    <div style="max-width:1120px;margin:0 auto;padding:0 32px;">
      <div style="max-width:680px;">
        <div style="font-size:11px;font-weight:900;letter-spacing:0.12em;text-transform:uppercase;color:#0B3D2E;margin-bottom:22px;">
          Startup Consultant
        </div>
        <h1 style="font-size:clamp(46px,7.5vw,76px);font-weight:900;letter-spacing:-0.048em;line-height:1.06;color:#0B0B0B;margin:0 0 28px;">
          {BRAND.name}
        </h1>
        <p style="font-size:clamp(17px,2.5vw,24px);font-weight:600;letter-spacing:-0.025em;line-height:1.3;color:#0B3D2E;margin:0 0 18px;max-width:540px;">
          Premium startup consulting—clarity, speed, control.
        </p>
        <p style="font-size:15px;color:#5F5F5F;line-height:1.68;margin:0 0 44px;max-width:500px;font-weight:450;">
          {BRAND.oneLiner}
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:center;">
          <a
            href="/contact"
            style="display:inline-flex;align-items:center;padding:14px 30px;background:#0B0B0B;color:#fff;border-radius:999px;font-size:14px;font-weight:700;letter-spacing:-0.01em;text-decoration:none;transition:opacity 0.15s ease;"
            onmouseover="this.style.opacity='0.82'"
            onmouseout="this.style.opacity='1'"
          >
            Book a call
          </a>
          <a
            href="/services"
            style="display:inline-flex;align-items:center;padding:13px 30px;background:#fff;color:#0B0B0B;border:1.5px solid #0B0B0B;border-radius:999px;font-size:14px;font-weight:600;letter-spacing:-0.01em;text-decoration:none;transition:background 0.15s ease;"
            onmouseover="this.style.background='#F6F6F6'"
            onmouseout="this.style.background='#fff'"
          >
            View services
          </a>
        </div>
      </div>
    </div>
  </section>

  <section style="background:#F6F6F6;border-bottom:1px solid #E8E8E8;">
    <div style="max-width:1120px;margin:0 auto;padding:0 32px;">
      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:0;padding:18px 0;">
        {PROOF_ITEMS.map((item, i) => (
          <div style={`display:flex;align-items:center;gap:10px;padding:8px 0;${i < PROOF_ITEMS.length - 1 ? 'padding-right:32px;margin-right:32px;border-right:1px solid #E8E8E8;' : ''}`}>
            <div style="width:5px;height:5px;background:#0B3D2E;border-radius:50%;flex-shrink:0;"></div>
            <span style="font-size:13px;font-weight:600;color:#0B0B0B;letter-spacing:-0.01em;">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section style="padding:92px 0;border-bottom:1px solid #E8E8E8;">
    <div style="max-width:1120px;margin:0 auto;padding:0 32px;">
      <div style="margin-bottom:56px;">
        <div style="font-size:11px;font-weight:900;letter-spacing:0.12em;text-transform:uppercase;color:#0B3D2E;margin-bottom:14px;">
          Services
        </div>
        <h2 style="font-size:clamp(24px,3.5vw,34px);font-weight:800;letter-spacing:-0.03em;line-height:1.18;color:#0B0B0B;margin:0;max-width:480px;">
          Two ways to engage.<br/>One standard of execution.
        </h2>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:20px;">
        {SERVICES.map((service) => (
          <div
            style="background:#fff;border:1px solid #E8E8E8;border-radius:14px;padding:36px;display:flex;flex-direction:column;transition:border-color 0.2s,box-shadow 0.2s;"
            onmouseover="this.style.borderColor='#c8c8c8';this.style.boxShadow='0 6px 28px rgba(0,0,0,0.07)'"
            onmouseout="this.style.borderColor='#E8E8E8';this.style.boxShadow='none'"
          >
            <div style="font-size:10px;font-weight:900;letter-spacing:0.1em;text-transform:uppercase;color:#0B3D2E;margin-bottom:14px;">{service.tag}</div>
            <h3 style="font-size:21px;font-weight:800;letter-spacing:-0.025em;color:#0B0B0B;margin:0 0 12px;">{service.name}</h3>
            <p style="font-size:13.5px;color:#5F5F5F;line-height:1.65;margin:0 0 28px;flex:1;">{service.description}</p>
            <div style="border-top:1px solid #E8E8E8;padding-top:24px;display:flex;flex-direction:column;gap:9px;">
              {service.includes.map((item) => (
                <div style="display:flex;align-items:center;gap:10px;">
                  <div style="width:4px;height:4px;background:#1E5EFF;border-radius:50%;flex-shrink:0;"></div>
                  <span style="font-size:13px;color:#0B0B0B;font-weight:500;">{item}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div style="margin-top:28px;">
        <a href="/services" style="font-size:13px;font-weight:600;color:#1E5EFF;text-decoration:none;letter-spacing:-0.01em;">
          Learn more about services →
        </a>
      </div>
    </div>
  </section>

  <section style="padding:92px 0;border-bottom:1px solid #E8E8E8;background:#F6F6F6;">
    <div style="max-width:1120px;margin:0 auto;padding:0 32px;">
      <div style="margin-bottom:56px;">
        <div style="font-size:11px;font-weight:900;letter-spacing:0.12em;text-transform:uppercase;color:#0B3D2E;margin-bottom:14px;">
          Approach
        </div>
        <h2 style="font-size:clamp(24px,3.5vw,34px);font-weight:800;letter-spacing:-0.03em;line-height:1.18;color:#0B0B0B;margin:0;">
          Problem → Plan → Path → Proof
        </h2>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;">
        {APPROACH_STEPS.map((step) => (
          <div style="background:#fff;border:1px solid #E8E8E8;border-radius:14px;padding:28px;">
            <div style="font-size:11px;font-weight:700;letter-spacing:0.06em;font-family:ui-monospace,monospace;color:#5F5F5F;margin-bottom:16px;">{step.number}</div>
            <h3 style="font-size:16px;font-weight:800;letter-spacing:-0.02em;color:#0B0B0B;margin:0 0 10px;">{step.title}</h3>
            <p style="font-size:13px;color:#5F5F5F;line-height:1.65;margin:0;">{step.description}</p>
          </div>
        ))}
      </div>

      <div style="margin-top:28px;">
        <a href="/approach" style="font-size:13px;font-weight:600;color:#1E5EFF;text-decoration:none;letter-spacing:-0.01em;">
          See the full framework →
        </a>
      </div>
    </div>
  </section>

  <section style="padding:92px 0;border-bottom:1px solid #E8E8E8;">
    <div style="max-width:1120px;margin:0 auto;padding:0 32px;">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;" class="block md:grid">
        <div>
          <div style="font-size:11px;font-weight:900;letter-spacing:0.12em;text-transform:uppercase;color:#0B3D2E;margin-bottom:14px;">
            The Bench
          </div>
          <h2 style="font-size:clamp(24px,3.5vw,34px);font-weight:800;letter-spacing:-0.03em;line-height:1.18;color:#0B0B0B;margin:0 0 18px;">
            A discreet, senior bench.
          </h2>
          <p style="font-size:14px;color:#5F5F5F;line-height:1.7;margin:0 0 28px;">
            {BRAND.premiumCopy}
          </p>
          <a href="/team" style="font-size:13px;font-weight:600;color:#1E5EFF;text-decoration:none;letter-spacing:-0.01em;">
            About the bench →
          </a>
        </div>

        <div style="display:flex;flex-wrap:wrap;gap:9px;">
          {BENCH_AREAS.map((area) => (
            <span
              style="display:inline-flex;align-items:center;padding:8px 18px;border:1px solid #E8E8E8;border-radius:999px;font-size:12px;font-weight:600;color:#0B0B0B;background:#fff;letter-spacing:-0.01em;cursor:default;transition:border-color 0.15s,color 0.15s,background 0.15s;"
              onmouseover="this.style.borderColor='#0B3D2E';this.style.color='#0B3D2E';this.style.background='#F6F6F6'"
              onmouseout="this.style.borderColor='#E8E8E8';this.style.color='#0B0B0B';this.style.background='#fff'"
            >
              {area}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section style="background:#0B3D2E;padding:100px 0;">
    <div style="max-width:1120px;margin:0 auto;padding:0 32px;text-align:center;">
      <div style="font-size:11px;font-weight:900;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.4);margin-bottom:22px;">
        Get started
      </div>
      <h2 style="font-size:clamp(26px,4.5vw,46px);font-weight:900;letter-spacing:-0.04em;line-height:1.1;color:#fff;margin:0 0 20px;max-width:640px;margin-left:auto;margin-right:auto;">
        Share your constraints. I'll map the fastest safe path forward.
      </h2>
      <p style="font-size:15px;color:rgba(255,255,255,0.55);margin:0 0 44px;">
        No obligation. 30 minutes. Clear next steps.
      </p>
      <div style="display:flex;justify-content:center;gap:12px;flex-wrap:wrap;">
        <a
          href="/contact"
          style="display:inline-flex;align-items:center;padding:14px 30px;background:#fff;color:#0B0B0B;border-radius:999px;font-size:14px;font-weight:700;letter-spacing:-0.01em;text-decoration:none;transition:opacity 0.15s ease;"
          onmouseover="this.style.opacity='0.88'"
          onmouseout="this.style.opacity='1'"
        >
          Book a call
        </a>
        <a
          href="/services"
          style="display:inline-flex;align-items:center;padding:13px 30px;background:rgba(255,255,255,0.1);color:#fff;border:1.5px solid rgba(255,255,255,0.28);border-radius:999px;font-size:14px;font-weight:600;letter-spacing:-0.01em;text-decoration:none;transition:background 0.15s ease;"
          onmouseover="this.style.background='rgba(255,255,255,0.2)'"
          onmouseout="this.style.background='rgba(255,255,255,0.1)'"
        >
          View services
        </a>
      </div>
    </div>
  </section>

</Layout>
