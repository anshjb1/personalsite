---
import Layout from '../layouts/Layout.astro';
import { Button } from '../components/Button';
import { Card } from '../components/Card';
import { Pill } from '../components/Pill';
import { BRAND, SERVICES_CORE, SERVICES_PODS, FRAMEWORK, EXPERIENCES, SKILLS } from '../lib/constants';
---

<Layout title="Ansh Bhatt — Premium Startup Consulting">
  <section class="py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-6">
      <div class="max-w-2xl">
        <h1 class="text-h1 text-ink mb-4">{BRAND.owner}</h1>
        <p class="text-h2 text-muted mb-8">
          Premium startup consulting—clarity, speed, control.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <Button client:load variant="primary" href="/contact">
            Book a call
          </Button>
          <Button client:load variant="secondary" href="/services">
            View services
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 bg-soft border-y border-line">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div>
          <p class="text-h3 text-ink mb-2">Operator-led delivery</p>
          <p class="text-sm text-muted">I run point, assemble the right bench, and ensure decisions are correct and execution is clean.</p>
        </div>
        <div>
          <p class="text-h3 text-ink mb-2">Discreet senior bench</p>
          <p class="text-sm text-muted">Legal, accounting, engineering, marketing, bid strategy, and domain specialists—only when stakes are high.</p>
        </div>
        <div>
          <p class="text-h3 text-ink mb-2">Clear plans + owners + dates</p>
          <p class="text-sm text-muted">Every milestone has a responsible party and a hard deadline. Risk stays controlled.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="work" class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-h3 text-muted mb-3">Experience</p>
      <h2 class="text-3xl font-black text-ink mb-12">Selected Work</h2>

      <div class="space-y-6">
        {EXPERIENCES.slice(0, 5).map((exp) => (
          <div class={`border border-line rounded-card p-6 ${exp.featured ? 'bg-pine/5 border-pine/20' : 'bg-white'}`}>
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-2 mb-4">
              <div>
                <div class="flex items-center gap-3 mb-1">
                  <h3 class="text-lg font-bold text-ink">{exp.title}</h3>
                  {exp.featured && (
                    <span class="px-2 py-0.5 bg-pine text-white text-[10px] font-bold rounded uppercase">Featured</span>
                  )}
                </div>
                {exp.url ? (
                  <a href={exp.url} target="_blank" rel="noopener" class="text-blue font-medium hover:underline">
                    {exp.company}
                  </a>
                ) : (
                  <p class="text-muted font-medium">{exp.company}</p>
                )}
              </div>
              <p class="text-sm text-muted font-mono">{exp.period}</p>
            </div>
            <ul class="space-y-2">
              {exp.highlights.map((h) => (
                <li class="text-sm text-muted flex gap-2">
                  <span class="text-pine flex-shrink-0">-</span>
                  {h}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-soft">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-h3 text-muted mb-3">Services</p>
      <h2 class="text-3xl font-black text-ink mb-12">What I Do</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <Card client:load>
          <h3 class="text-xl font-bold text-ink mb-3">{SERVICES_CORE.name}</h3>
          <p class="text-sm text-muted mb-6">{SERVICES_CORE.value}</p>
          <ul class="space-y-2">
            {SERVICES_CORE.includes.map((item) => (
              <li class="text-sm text-muted flex gap-2">
                <span class="text-pine">-</span>
                {item}
              </li>
            ))}
          </ul>
        </Card>

        <Card client:load>
          <h3 class="text-xl font-bold text-ink mb-3">{SERVICES_PODS.name}</h3>
          <p class="text-sm text-muted mb-6">A discreet, senior bench assembled only when stakes are high.</p>
          <div class="flex flex-wrap gap-2">
            {SERVICES_PODS.areas.map((area) => (
              <Pill client:load>{area}</Pill>
            ))}
          </div>
        </Card>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-h3 text-muted mb-3">Approach</p>
      <h2 class="text-3xl font-black text-ink mb-12">{FRAMEWORK.title}</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {FRAMEWORK.steps.map((step, i) => (
          <div class="relative">
            <div class="text-pine text-4xl font-black mb-3">0{i + 1}</div>
            <h3 class="text-lg font-bold text-ink mb-2">{step.title}</h3>
            <p class="text-sm text-muted">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-soft">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-h3 text-muted mb-3">Capabilities</p>
      <h2 class="text-3xl font-black text-ink mb-12">Skills & Tools</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {Object.entries(SKILLS).map(([category, items]) => (
          <div>
            <h3 class="text-sm font-bold text-ink mb-3">{category}</h3>
            <div class="flex flex-wrap gap-2">
              {items.map((item) => (
                <Pill client:load className="bg-white">{item}</Pill>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-pine text-white">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="text-3xl md:text-4xl font-black mb-6">
        Share your constraints. I'll map the fastest safe path forward.
      </h2>
      <Button client:load href="/contact" className="bg-white text-ink hover:bg-white/90">
        Book a call
      </Button>
    </div>
  </section>
</Layout>
