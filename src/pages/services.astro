---
import Layout from '../layouts/Layout.astro';
import { Card } from '../components/Card';
import { Button } from '../components/Button';
import { Pill } from '../components/Pill';
import { SERVICES_CORE, SERVICES_PODS } from '../lib/constants';
---

<Layout title="Services — Ansh Bhatt">
  <div class="bg-white">
    <section class="section py-20">
      <div class="container max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-black mb-6">Services</h1>
        <p class="text-lg text-[#5F5F5F] mb-12">
          Two core offerings designed to reduce risk and accelerate momentum.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container max-w-3xl">
        <div class="mb-16">
          <h2 class="text-3xl font-black mb-6">{SERVICES_CORE.name}</h2>
          <p class="text-lg text-[#5F5F5F] mb-8">{SERVICES_CORE.value}</p>
          <Card client:load className="bg-[#F6F6F6]">
            <ul class="space-y-4">
              {SERVICES_CORE.includes.map((item) => (
                <li class="flex gap-3">
                  <span class="text-[#1E5EFF] font-bold flex-shrink-0">✓</span>
                  <span class="text-[#0B0B0B]">{item}</span>
                </li>
              ))}
            </ul>
          </Card>
        </div>

        <div>
          <h2 class="text-3xl font-black mb-6">{SERVICES_PODS.name}</h2>
          <p class="text-lg text-[#5F5F5F] mb-8">
            A discreet, senior bench assembled only when stakes are high. I coordinate legal, accounting, engineering, marketing, RFA/bid strategy, and domain specialists (healthtech, fintech, evergreen online brands).
          </p>
          <div class="flex flex-wrap gap-3 mb-12">
            {SERVICES_PODS.areas.map((area) => (
              <Pill client:load className="bg-[#F6F6F6]">{area}</Pill>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section bg-[#F6F6F6]">
      <div class="container max-w-3xl">
        <h2 class="text-3xl font-black mb-12">How it works</h2>
        <div class="space-y-8">
          <div>
            <h3 class="text-lg font-bold text-[#0B0B0B] mb-3">Engagements start with diagnosis</h3>
            <p class="text-[#5F5F5F]">We map constraints, options, and tradeoffs. You decide the path forward.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-[#0B0B0B] mb-3">I run point</h3>
            <p class="text-[#5F5F5F]">As your operator-consultant, I orchestrate the bench, manage cadence, and ensure every decision has clear ownership and dates.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-[#0B0B0B] mb-3">Weekly operating cadence</h3>
            <p class="text-[#5F5F5F]">Status, risks, decisions, next actions. No surprises. Momentum maintained.</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-[#0B0B0B] mb-3">Outcomes over announcements</h3>
            <p class="text-[#5F5F5F]">Discreet, measured, precise. Results matter more than the noise.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container max-w-2xl text-center">
        <h2 class="text-3xl font-black mb-8">Ready to discuss your needs?</h2>
        <Button client:load variant="primary" href="/contact" className="text-base px-8 py-4">
          Book a call
        </Button>
      </div>
    </section>
  </div>
</Layout>
