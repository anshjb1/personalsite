---
import Layout from '../layouts/Layout.astro';
import { Card } from '../components/Card';
import { Button } from '../components/Button';
import { Pill } from '../components/Pill';
import { SERVICES_CORE, SERVICES_PODS } from '../lib/constants';
---

<Layout title="Services — Ansh Bhatt">
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-h3 text-muted mb-3">Services</p>
      <h1 class="text-h1 text-ink mb-6">What I Do</h1>
      <p class="text-lg text-muted">
        Two core offerings designed to reduce risk and accelerate momentum.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-6">
      <div class="mb-16">
        <h2 class="text-2xl font-black text-ink mb-4">{SERVICES_CORE.name}</h2>
        <p class="text-muted mb-8">{SERVICES_CORE.value}</p>
        <Card client:load variant="soft">
          <ul class="space-y-4">
            {SERVICES_CORE.includes.map((item) => (
              <li class="flex gap-3">
                <span class="text-pine font-bold flex-shrink-0">-</span>
                <span class="text-ink">{item}</span>
              </li>
            ))}
          </ul>
        </Card>
      </div>

      <div>
        <h2 class="text-2xl font-black text-ink mb-4">{SERVICES_PODS.name}</h2>
        <p class="text-muted mb-8">
          A discreet, senior bench assembled only when stakes are high. I coordinate legal, accounting, engineering, marketing, RFA/bid strategy, and domain specialists.
        </p>
        <div class="flex flex-wrap gap-2">
          {SERVICES_PODS.areas.map((area) => (
            <Pill client:load className="bg-soft">{area}</Pill>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-soft">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-2xl font-black text-ink mb-10">How it works</h2>
      <div class="space-y-8">
        <div>
          <h3 class="font-bold text-ink mb-2">Engagements start with diagnosis</h3>
          <p class="text-muted">We map constraints, options, and tradeoffs. You decide the path forward.</p>
        </div>
        <div>
          <h3 class="font-bold text-ink mb-2">I run point</h3>
          <p class="text-muted">As your operator-consultant, I orchestrate the bench, manage cadence, and ensure every decision has clear ownership and dates.</p>
        </div>
        <div>
          <h3 class="font-bold text-ink mb-2">Weekly operating cadence</h3>
          <p class="text-muted">Status, risks, decisions, next actions. No surprises. Momentum maintained.</p>
        </div>
        <div>
          <h3 class="font-bold text-ink mb-2">Outcomes over announcements</h3>
          <p class="text-muted">Discreet, measured, precise. Results matter more than the noise.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-2xl font-black text-ink mb-6">Ready to discuss your needs?</h2>
      <Button client:load variant="primary" href="/contact">
        Book a call
      </Button>
    </div>
  </section>
</Layout>
