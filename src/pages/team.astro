---
import Layout from '../layouts/Layout.astro';
import { Pill } from '../components/Pill';
import { Button } from '../components/Button';
import { SERVICES_PODS } from '../lib/constants';
---

<Layout title="Team Bench — Ansh Bhatt">
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-h3 text-muted mb-3">Team Bench</p>
      <h1 class="text-h1 text-ink mb-6">Senior Specialists</h1>
      <p class="text-lg text-muted">
        A discreet network of senior operators. Assembled only when stakes are high.
      </p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-3xl mx-auto px-6">
      <div class="mb-12">
        <h2 class="text-xl font-bold text-ink mb-6">Core Specializations</h2>
        <div class="flex flex-wrap gap-2">
          {SERVICES_PODS.areas.map((area) => (
            <Pill client:load className="bg-soft text-ink">{area}</Pill>
          ))}
        </div>
      </div>

      <div class="bg-soft p-8 rounded-card border border-line">
        <h3 class="font-bold text-ink mb-6">How the bench works</h3>
        <div class="space-y-4 text-muted">
          <p>
            <span class="font-bold text-ink">No bench bloat.</span> You pay for seniority only when you need it.
          </p>
          <p>
            <span class="font-bold text-ink">I coordinate.</span> You get one point of contact. I ensure alignment across all specialists.
          </p>
          <p>
            <span class="font-bold text-ink">Built for trust.</span> Every bench member is vetted, experienced, and aligned on your priorities.
          </p>
          <p>
            <span class="font-bold text-ink">Clear engagement terms.</span> Scope, timeline, and costs stated upfront. No surprises.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-soft">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="text-xl font-black text-ink mb-4">Need a specific expert?</h2>
      <p class="text-muted mb-6">
        Tell me what you're building and what you need. I'll get the right person involved.
      </p>
      <Button client:load variant="primary" href="/contact">
        Get in touch
      </Button>
    </div>
  </section>
</Layout>
