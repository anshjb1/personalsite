---
import Layout from '../layouts/Layout.astro';
import { Pill } from '../components/Pill';
import { SERVICES_PODS } from '../lib/constants';
---

<Layout title="Team Bench — Ansh Bhatt">
  <div class="bg-white">
    <section class="section py-20">
      <div class="container max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-black mb-6">Team Bench</h1>
        <p class="text-lg text-[#5F5F5F]">
          A discreet network of senior operators. Assembled only when stakes are high.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container max-w-3xl">
        <div class="mb-12">
          <h2 class="text-2xl font-bold text-[#0B0B0B] mb-6">Core Specializations</h2>
          <div class="flex flex-wrap gap-3">
            {SERVICES_PODS.areas.map((area) => (
              <Pill client:load className="bg-[#F6F6F6] text-[#0B0B0B]">{area}</Pill>
            ))}
          </div>
        </div>

        <div class="bg-[#F6F6F6] p-8 rounded-lg border border-[#E8E8E8]">
          <h3 class="text-lg font-bold text-[#0B0B0B] mb-4">How the bench works</h3>
          <div class="space-y-4 text-[#5F5F5F]">
            <p>
              <span class="font-bold text-[#0B0B0B]">No bench bloat.</span> You pay for seniority only when you need it.
            </p>
            <p>
              <span class="font-bold text-[#0B0B0B]">I coordinate.</span> You get one point of contact. I ensure alignment across all specialists.
            </p>
            <p>
              <span class="font-bold text-[#0B0B0B]">Built for trust.</span> Every bench member is vetted, experienced, and aligned on your priorities.
            </p>
            <p>
              <span class="font-bold text-[#0B0B0B]">Clear engagement terms.</span> Scope, timeline, and costs stated upfront. No surprises.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section bg-[#F6F6F6]">
      <div class="container max-w-2xl text-center">
        <h2 class="text-2xl font-black text-[#0B0B0B] mb-4">Need a specific expert?</h2>
        <p class="text-[#5F5F5F] mb-6">
          Tell me what you're building and what you need. I'll get the right person involved.
        </p>
        <a
          href="/contact"
          class="inline-flex items-center justify-center px-6 py-3 rounded-full font-bold bg-[#0B0B0B] text-white hover:bg-opacity-90 transition text-sm"
        >
          Get in touch
        </a>
      </div>
    </section>
  </div>
</Layout>
